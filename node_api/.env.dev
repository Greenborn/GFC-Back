# Mapeo email → role_id para usuarios SSO (JSON)
# 1=Administrador, 2=Delegado, 3=Concursante
# *@dominio.com aplica a todos los emails de ese dominio
# SSO_ROLE_MAP={"admin@greenborn.com.ar":1,"*@delegados.gfc.com":2}